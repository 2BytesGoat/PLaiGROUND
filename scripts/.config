# You can get your ENV_PATH from the `~` developer console inside the game
ENV_PATH="D:/gamedev/dragon-jump-remaster/builds/windows"
ENV_NAME="DragonJump"

# Training information
LEVEL="1-1"
NB_AGENTS=1

# This tells the game how many frames to keep the same action
ACTION_REPEAT=2

# This sets the run speed for the game
SPEEDUP=1
SHOW_WINDOW=TRUE